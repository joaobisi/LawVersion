<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LawVersion.UI.ViewModels"
        xmlns:converters="using:LawVersion.UI.Converters"
        x:Class="LawVersion.UI.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:Name="RootWindow"
        Title="LawVersion P2P" 
        Width="700" Height="550"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:TupleConverter x:Key="TupleConverter"/>
    </Window.Resources>

    <Grid>
        <Grid Margin="24" RowDefinitions="Auto, *, Auto">
            <Border Grid.Row="0" 
                    Background="#1E1E2E" CornerRadius="12" 
                    Padding="20,16" Margin="0,0,0,16">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Spacing="4">
                        <TextBlock Text="LawVersion" FontSize="22" FontWeight="Bold" Foreground="#CDD6F4"/>
                        <TextBlock Text="{Binding LawyerName, StringFormat='👤 {0}'}" 
                                   FontSize="13" Foreground="#89B4FA"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" 
                            Content="＋ Importar" 
                            Command="{Binding OpenImportModalCommand}"
                            Background="#89B4FA" Foreground="#1E1E2E"
                            FontWeight="SemiBold"
                            Padding="16,8" CornerRadius="8"/>
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="#1E1E2E" CornerRadius="12" Padding="4">
                <ListBox ItemsSource="{Binding Documents}" 
                         Background="Transparent" CornerRadius="8">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" Margin="4,2" 
                                    CornerRadius="8" Background="#181825">
                                <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                    <Border Grid.Column="0" 
                                            Width="36" Height="36" CornerRadius="8"
                                            Background="{Binding StatusColor}" Opacity="0.15">
                                        <PathIcon Width="18" Height="18"
                                                  Data="{Binding StatusIcon}" 
                                                  Foreground="{Binding StatusColor}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                            
                                    <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontWeight="Medium" FontSize="14" 
                                                   Foreground="#CDD6F4"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding StatusText}" 
                                                       FontSize="11" 
                                                       Foreground="{Binding StatusColor}"/>
                                            <TextBlock Text="•" FontSize="11" Foreground="#585B70"/>
                                            <TextBlock Text="{Binding SharingText}" 
                                                       FontSize="11" 
                                                       Foreground="#A6ADC8"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                            Content="Abrir"
                                            FontSize="11" Padding="12,6" CornerRadius="6"
                                            Background="#45475A" Foreground="#CDD6F4"
                                            IsVisible="{Binding !IsLockedByOther}"
                                            Command="{Binding #RootWindow.DataContext.OpenDocumentCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}"
                                            Margin="0,0,6,0"/>

                                    <Button Grid.Column="3" 
                                            Content="⋮" 
                                            FontSize="14" Padding="10,4" CornerRadius="6"
                                            Background="#313244" Foreground="#CDD6F4"
                                            Cursor="Hand">
                                        <Button.Flyout>
                                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                <MenuItem Header="Compartilhar" 
                                                          Command="{Binding #RootWindow.DataContext.OpenShareModalCommand, FallbackValue={x:Null}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Histórico" 
                                                          Command="{Binding #RootWindow.DataContext.ShowHistoryCommand, FallbackValue={x:Null}}"
                                                          CommandParameter="{Binding}"/>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Row="2" 
                    Background="#1E1E2E" CornerRadius="8"
                    Padding="12,8" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="11" Foreground="#6C7086"/>
            </Border>
        </Grid>

        <Grid Background="#A0000000" 
              IsVisible="{Binding IsHistoryVisible}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#313244" BorderThickness="1"
                    Width="500" Height="380" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <TextBlock Text="{Binding SelectedDocumentName, StringFormat='📋 Histórico: {0}'}" 
                                   FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" 
                                Command="{Binding CloseHistoryCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#F38BA8" Padding="6" FontSize="16"
                                Cursor="Hand"/>
                    </Grid>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedFileHistoryLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="12,10" Background="#181825" CornerRadius="8">
                                        <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                            <TextBlock Grid.Column="0" Text="🔹" Foreground="#89B4FA" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayText}" FontSize="12" Foreground="#CDD6F4" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                            
                                            <Button Grid.Column="2" Content="Visualizar"
                                                    Command="{Binding #RootWindow.DataContext.ViewVersionCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding Sha, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    Background="#89B4FA" Foreground="#1E1E2E"
                                                    FontSize="10" Padding="8,4" CornerRadius="4"
                                                    VerticalAlignment="Center" Margin="8,0,0,0"
                                                    Cursor="Hand"/>
                                            
                                            <Button Grid.Column="3" Content="Restaurar"
                                                    Command="{Binding #RootWindow.DataContext.RestoreVersionCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding Sha, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                    IsEnabled="{Binding !#RootWindow.DataContext.IsSelectedDocumentLockedByOther}"
                                                    Background="#F38BA8" Foreground="#1E1E2E"
                                                    FontSize="10" Padding="8,4" CornerRadius="4"
                                                    VerticalAlignment="Center" Margin="8,0,0,0"
                                                    Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Background="#A0000000" 
              IsVisible="{Binding IsShareModalVisible}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#313244" BorderThickness="1"
                    Width="450" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <TextBlock Text="{Binding SharingDocument.Name, StringFormat='🔗 Compartilhar: {0}'}" 
                                   FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" 
                                Command="{Binding CloseShareModalCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#F38BA8" Padding="6" FontSize="16"
                                Cursor="Hand"/>
                    </Grid>
                    
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <TextBlock Text="Nenhum colega detectado na rede local." 
                                       Foreground="#A6ADC8" FontSize="13" HorizontalAlignment="Center" 
                                       IsVisible="{Binding !SharePeers.Count}" Margin="0,40,0,0"/>
                            
                            <ItemsControl ItemsSource="{Binding SharePeers}" IsVisible="{Binding SharePeers.Count}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4" Padding="12,8" Background="#181825" CornerRadius="8">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                    <TextBlock Text="👤" Foreground="#89B4FA" FontSize="14"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#CDD6F4"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" 
                                                        Content="{Binding ButtonText}"
                                                        Command="{Binding #RootWindow.DataContext.ConfirmShareCommand}"
                                                        CommandParameter="{Binding}"
                                                        Background="{Binding ButtonColor}" 
                                                        Foreground="{Binding ButtonTextColor}"
                                                        IsEnabled="{Binding CanShare}"
                                                        FontSize="11" Padding="10,4" CornerRadius="6"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Background="#A0000000" 
              IsVisible="{Binding IsImportModalVisible}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#313244" BorderThickness="1"
                    Width="450" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <TextBlock Text="＋ Importar Documento" 
                                   FontSize="16" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="✕" 
                                Command="{Binding CloseImportModalCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#F38BA8" Padding="6" FontSize="16"
                                Cursor="Hand"/>
                    </Grid>
                    
                    <StackPanel Spacing="16" VerticalAlignment="Center">
                        <Border BorderBrush="#313244" BorderThickness="1" CornerRadius="8" Padding="16" Background="#181825">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Button Content="Selecionar Arquivo (.docx)"
                                        Command="{Binding SelectImportFileCommand}"
                                        CommandParameter="{Binding $parent[Window]}"
                                        Background="#45475A" Foreground="#CDD6F4"
                                        HorizontalAlignment="Center" Padding="14,8" CornerRadius="6"/>
                                <TextBlock Text="{Binding ImportFileName}" 
                                           HorizontalAlignment="Center"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#89B4FA"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding ImportFilePath}" 
                                           HorizontalAlignment="Center"
                                           FontSize="11" Foreground="#6C7086"
                                           TextWrapping="Wrap" MaxHeight="40"/>
                            </StackPanel>
                        </Border>
                        
                        <Grid ColumnDefinitions="*, *">
                            <Button Grid.Column="0" Content="Cancelar" 
                                    Command="{Binding CloseImportModalCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="Transparent" Foreground="#F38BA8" Padding="10" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Confirmar" 
                                    Command="{Binding ConfirmImportCommand}"
                                    IsEnabled="{Binding ImportFilePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="#89B4FA" Foreground="#1E1E2E" Padding="10" Margin="6,0,0,0"
                                    FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Background="#A0000000" 
              IsVisible="{Binding IsConfirmRestoreVisible}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#313244" BorderThickness="1"
                    Width="400" Height="220" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="24">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="⚠️ Confirmar Restauração" 
                               FontSize="16" FontWeight="Bold" Foreground="#F38BA8" Margin="0,0,0,12"/>
                    
                    <StackPanel Spacing="16" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConfirmRestoreMessage}" 
                                   Foreground="#CDD6F4" FontSize="13" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" TextAlignment="Center"/>
                        
                        <Grid ColumnDefinitions="*, *">
                            <Button Grid.Column="0" Content="Cancelar" 
                                    Command="{Binding CancelRestoreCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="Transparent" Foreground="#F38BA8" Padding="10" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Content="Confirmar" 
                                    Command="{Binding ConfirmRestoreCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Background="#F38BA8" Foreground="#1E1E2E" Padding="10" Margin="6,0,0,0"
                                    FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>